# Copy to .env and fill in only the keys you need.

# Track A — AssemblyAI Universal-2 (transcribe + diarize + summarize).
ASSEMBLYAI_API_KEY=

# Track B — transcription options. ELEVENLABS_API_KEY is the default
# (Scribe v2) and also covers diarization via --diarizer builtin.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# ElevenLabs Scribe v2 timeout (seconds). Default 1800 (30 min). Increase for long audio.
# ELEVENLABS_TIMEOUT=3600
DEEPGRAM_API_KEY=

# Track B — optional alternative diarizer (pyannoteAI Premium API; no GPU
# needed). Only required when --diarizer pyannoteai is selected.
PYANNOTEAI_API_KEY=

# Track B — summarization (pick one).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional — local pyannote fallback (Hugging Face token for pyannote/speaker-diarization-3.1).
HF_TOKEN=
